generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  hoTen        String?
  passwordHash String
  role         Role    @default(CONG_DAN)
  hoSo         HoSo[]
}

// Hồ sơ dịch vụ công (dossier) — tra cứu sau khi đăng nhập
model HoSo {
  id           String   @id @default(cuid())
  maHoSo       String   @unique
  thuTuc       String
  coQuan       String
  linhVuc      String
  nguoiNop     String
  tinhTrang    String
  ngayTiepNhan DateTime
  ngayHenTra   DateTime
  ownerId      String?
  owner        User?    @relation(fields: [ownerId], references: [id])
}

enum Role {
  CONG_DAN
  CAN_BO
  ADMIN
}
